{
  "description": "Dream Team session hooks — ensures memory skeleton in opted-in projects; logs failed Bash commands to the error ledger",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT}/scripts/bootstrap.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT}/scripts/log-error.sh\""
          }
        ]
      }
    ]
  }
}
